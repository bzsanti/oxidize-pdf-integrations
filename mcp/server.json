{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.bzsanti/oxidize-pdf-mcp",
  "title": "oxidize-pdf MCP Server",
  "description": "MCP server for PDF generation, parsing, splitting, merging, and manipulation via oxidize-pdf",
  "version": "0.5.0",
  "repository": {
    "url": "https://github.com/bzsanti/oxidize-python",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "oxidize-pdf",
      "version": "0.5.0",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "oxidize-mcp"
        }
      ]
    }
  ]
}
